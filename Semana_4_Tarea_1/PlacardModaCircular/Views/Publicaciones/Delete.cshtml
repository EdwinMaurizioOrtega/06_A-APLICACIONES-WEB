@model PlacardModaCircular.Models.Publicaciones

@{
    ViewData["Title"] = "Eliminar Publicación";
}

<h1>Eliminar</h1>

<h3>¿Está seguro que desea eliminar esta publicación?</h3>
<div>
    <h4>Publicación</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.PrecioOferta)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.PrecioOferta)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Descripcion)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Descripcion)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.FechaPublicacion)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.FechaPublicacion)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Estado)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Estado)</dd>
        <dt class="col-sm-2">Usuario</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Usuarios.NombreCompleto)</dd>
        <dt class="col-sm-2">Prenda</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Prendas.Nombre)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Eliminar" class="btn btn-danger" /> |
        <a asp-action="Index">Volver a la lista</a>
    </form>
</div>
