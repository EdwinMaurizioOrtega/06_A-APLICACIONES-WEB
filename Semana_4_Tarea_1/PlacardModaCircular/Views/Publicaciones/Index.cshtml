@model IEnumerable<PlacardModaCircular.Models.Publicaciones>

@{
    ViewData["Title"] = "Publicaciones";
}

<h1>Publicaciones</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Nueva Publicación</a>
</p>
<table class="table table-striped">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.PrecioOferta)</th>
            <th>@Html.DisplayNameFor(model => model.Descripcion)</th>
            <th>@Html.DisplayNameFor(model => model.FechaPublicacion)</th>
            <th>@Html.DisplayNameFor(model => model.Estado)</th>
            <th>Usuario</th>
            <th>Prenda</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.PrecioOferta)</td>
            <td>@Html.DisplayFor(modelItem => item.Descripcion)</td>
            <td>@Html.DisplayFor(modelItem => item.FechaPublicacion)</td>
            <td>@Html.DisplayFor(modelItem => item.Estado)</td>
            <td>@Html.DisplayFor(modelItem => item.Usuarios.NombreCompleto)</td>
            <td>@Html.DisplayFor(modelItem => item.Prendas.Nombre)</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Detalles</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
            </td>
        </tr>
}
    </tbody>
</table>
