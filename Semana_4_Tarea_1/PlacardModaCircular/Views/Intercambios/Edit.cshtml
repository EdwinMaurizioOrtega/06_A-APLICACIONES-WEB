@model PlacardModaCircular.Models.Intercambios

@{
    ViewData["Title"] = "Editar Intercambio";
}

<h1>Editar Intercambio</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group mb-3">
                <label asp-for="Mensaje" class="control-label"></label>
                <input asp-for="Mensaje" class="form-control" />
                <span asp-validation-for="Mensaje" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="FechaIntercambio" class="control-label"></label>
                <input asp-for="FechaIntercambio" class="form-control" />
                <span asp-validation-for="FechaIntercambio" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Estado" class="control-label"></label>
                <input asp-for="Estado" class="form-control" />
                <span asp-validation-for="Estado" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="UsuarioOfertanteId" class="control-label">Ofertante</label>
                <select asp-for="UsuarioOfertanteId" class="form-control" asp-items="ViewBag.UsuarioOfertanteId"></select>
                <span asp-validation-for="UsuarioOfertanteId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="PublicacionId" class="control-label">Publicación</label>
                <select asp-for="PublicacionId" class="form-control" asp-items="ViewBag.PublicacionId"></select>
                <span asp-validation-for="PublicacionId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Guardar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Volver a la lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
