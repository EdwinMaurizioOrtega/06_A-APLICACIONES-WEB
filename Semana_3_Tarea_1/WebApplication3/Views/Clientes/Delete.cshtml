@model WebApplication2.Models.ClienteModel

@{
    ViewData["Title"] = "Eliminar Cliente";
}

<div class="container">
    <h1 class="mb-4 text-danger"><i class="bi bi-exclamation-triangle-fill"></i> @ViewData["Title"]</h1>
    <h3 class="text-muted">¿Está seguro de eliminar este cliente?</h3>
    <hr />

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Nombres_Cliente)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Nombres_Cliente)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Apellidos)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Apellidos)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Cedula)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Cedula)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.FechaNacimiento)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.FechaNacimiento)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Genero)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Genero)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Direccion)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Direccion)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Ciudad)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Ciudad)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Nacionalidad)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Nacionalidad)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Telefono)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Telefono)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Correo)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Correo)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.EstadoCivil)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.EstadoCivil)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Profesion)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Profesion)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.FechaRegistro)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.FechaRegistro)</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" class="mt-3">
        <input type="hidden" asp-for="id" />
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash-fill"></i> Eliminar
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver a la lista
        </a>
    </form>
</div>
