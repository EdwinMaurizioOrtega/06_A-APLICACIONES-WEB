@model WebApplication2.Models.ClienteModel

@{
    ViewData["Title"] = "Detalles del Cliente";
}

<div class="container">
    <h1 class="mb-4"><i class="bi bi-person-vcard-fill"></i> @ViewData["Title"]</h1>
    <hr />

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">@Model.Nombres_Cliente @Model.Apellidos</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Nombres_Cliente)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Nombres_Cliente)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Apellidos)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Apellidos)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Cedula)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Cedula)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.FechaNacimiento)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.FechaNacimiento)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Genero)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Genero)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Direccion)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Direccion)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Ciudad)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Ciudad)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Nacionalidad)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Nacionalidad)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Telefono)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Telefono)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Correo)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Correo)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.EstadoCivil)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.EstadoCivil)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Profesion)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Profesion)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.FechaRegistro)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.FechaRegistro)</dd>
            </dl>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Edit" asp-route-id="@Model?.id" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Editar
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver a la lista
        </a>
    </div>
</div>
